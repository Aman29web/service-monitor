# Server Configuration
PORT=4000
NODE_ENV=development

# MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://aman:aman123@cluster0.fox6lwo.mongodb.net/network-scanner?retryWrites=true&w=majority

# JWT Secret (shared with slave agents — keep this secure!)
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars

# JWT Expiry for slave tokens (long-lived since slaves run continuously)
JWT_SLAVE_EXPIRY=365d

# CORS - comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend.vercel.app

# Health Check Config (milliseconds)
NODE_TIMEOUT_MS=40000
